  "keyFeatures": [
    "Full TypeScript type definitions for all API responses",
    "Declarative API with method chaining",
    "Built-in pagination support with next() cursor",
    "Optional filters for flexible querying (gt, gte, lt, lte, ne)",
    "Fetch API by default (Axios optional)",
    "Support for Accounts, Transactions, Topics, Tokens, NFTs, and Smart Contracts",
    "Helper utilities for token and NFT operations",
    "Pluggable HTTP client architecture"
  ],
  "publicApiSurface": [
    "Client (FetchClient)",
